{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build, Upload & Monitor (Arduino CLI)",
      "type": "shell",
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\.vscode\\scripts\\arduino_build_upload_monitor.ps1"
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
