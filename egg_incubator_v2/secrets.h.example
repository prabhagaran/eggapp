// secrets.h.example
// Copy this file to `secrets.h` and fill in the real values. DO NOT commit
// your `secrets.h` — it should be gitignored.

// Example Google Apps Script URL (replace with your deployed URL)
#define GOOGLE_SCRIPT_URL \
  "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

// Shared secret token used by the cloud script. Keep this private.
#define CLOUD_TOKEN  "REPLACE_WITH_A_STRONG_RANDOM_TOKEN"

// Optional: Root CA certificate (PEM) for the cloud server. When populated,
// the firmware will call `client.setCACert(CLOUD_ROOT_CA)` and TLS server
// certificate verification will be enforced. Leave empty to use setInsecure().
// Example: paste the PEM with \n newlines. Remove the example payload below.
#define CLOUD_ROOT_CA "-----BEGIN CERTIFICATE-----\nMIIF...REPLACE...\n-----END CERTIFICATE-----\n"
