// Owner: database-architect. Entities follow docs/architecture/domain-model.md;
// conceptual changes go through system-architect.
//
// Scoping (BR-013 / ADR 0003): aggregate roots carry farmId; nested records
// (BatchEggSource, CandlingSession, HatchEvent, telemetry/config/events)
// scope through their root's FK. Cross-context references (recordedById,
// ackedById) are plain IDs, not FKs — contexts stay loosely coupled.
//
// Enum values are lowercase to match the canonical enums in
// packages/shared-types (no mapping layer at the API boundary).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Farm & Access ────────────────────────────────────────────────

enum FarmRole {
  owner
  manager
  worker
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  passwordHash String
  name         String
  tokenVersion Int              @default(0) // bump = revoke all refresh tokens
  fcmToken     String? // current device's push token (US-NOT-002); one per user — personal-scale, single phone
  createdAt    DateTime         @default(now())
  memberships  FarmMembership[]
}

model Farm {
  id                       String                    @id @default(uuid())
  name                     String
  location                 String?
  timezone                 String
  createdAt                DateTime                  @default(now())
  memberships              FarmMembership[]
  devices                  Device[]
  incubators               Incubator[]
  collections              EggCollection[]
  batches                  EggBatch[]
  alertRules               AlertRule[]
  alerts                   Alert[]
  flocks                   Flock[]
  vaccinationTemplateItems VaccinationTemplateItem[]
  inventoryItems           InventoryItem[]
}

model FarmMembership {
  userId    String
  farmId    String
  role      FarmRole
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@id([userId, farmId])
  @@index([farmId])
}

// ── Species reference (seeded, domain-knowledge §1; drives BR-008) ──

model Species {
  id                       String                    @id // slug, e.g. "chicken"
  name                     String
  incubationDays           Int
  lockdownOffsetDays       Int // lockdown = incubationDays - this
  tempSetC                 Float
  tempMinC                 Float // sustained outside min/max = critical (BR-006)
  tempMaxC                 Float
  humidityIncubMinPct      Int
  humidityIncubMaxPct      Int
  humidityLockMinPct       Int
  humidityLockMaxPct       Int
  candlingDays             Int[]
  turnUntilDay             Int
  batches                  EggBatch[]
  incubators               Incubator[]
  flocks                   Flock[]
  vaccinationTemplateItems VaccinationTemplateItem[]
}

// ── Device & Telemetry ───────────────────────────────────────────

enum DeviceStatus {
  provisioned
  active
  offline
  decommissioned
}

enum ConfigState {
  sent
  received
  applied
  unconfirmed
}

enum TelemetrySource {
  mqtt
  ble
}

enum DeviceEventType {
  provisioned
  online
  offline
  decommissioned
  config_sent
  config_received
  config_applied
}

model Device {
  id                        String             @id @default(uuid())
  farmId                    String
  hardwareId                String             @unique // e.g. ESP32 MAC
  name                      String?
  status                    DeviceStatus       @default(provisioned)
  lastSeenAt                DateTime?
  firmwareVersion           String?
  // Latest known control-loop values, mirrored from telemetry's setTemp/
  // setHum/setTempHyst/setHumHyst on every message (US-INC-003 — the
  // remote setpoint UI needs to show what it's about to change). A
  // snapshot, not a history — TelemetryReading rows stay unchanged.
  currentTempSetpoint       Float?
  currentTempHysteresis     Float?
  currentHumSetpoint        Float?
  currentHumHysteresis      Float?
  // Same snapshot idiom, mirrored from telemetry's fan/turner/humidifier/
  // pump + *Override fields — lets a remote actuator toggle UI show
  // current on/off and auto-vs-manual state before the user changes it.
  currentFanOn              Boolean?
  currentFanOverride        Boolean?
  currentTurnerOn           Boolean?
  currentTurnerOverride     Boolean?
  currentHumidifierOn       Boolean?
  currentHumidifierOverride Boolean?
  currentPumpOn             Boolean?
  currentPumpOverride       Boolean?
  createdAt                 DateTime           @default(now())
  farm                      Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  incubator                 Incubator? // set via Incubator.deviceId (BR-007: 0..1)
  events                    DeviceEvent[]
  configs                   DeviceConfig[]
  telemetry                 TelemetryReading[]

  @@index([farmId])
}

model Incubator {
  id               String     @id @default(uuid())
  farmId           String
  name             String
  capacity         Int
  defaultSpeciesId String?
  deviceId         String?    @unique // BR-007: a device binds to at most one incubator
  createdAt        DateTime   @default(now())
  farm             Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  defaultSpecies   Species?   @relation(fields: [defaultSpeciesId], references: [id])
  device           Device?    @relation(fields: [deviceId], references: [id])
  batches          EggBatch[]

  @@index([farmId])
}

// Append-only time series (NFR: plain table + index is sufficient at scale)
model TelemetryReading {
  id           BigInt          @id @default(autoincrement())
  deviceId     String
  ts           DateTime
  tempC        Float?
  humidityPct  Float?
  heaterOn     Boolean?
  coolerOn     Boolean?
  humidifierOn Boolean?
  fanOn        Boolean?
  pumpOn       Boolean?
  turnerOn     Boolean?
  source       TelemetrySource @default(mqtt)
  device       Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, ts(sort: Desc)])
}

model DeviceEvent {
  id       String          @id @default(uuid())
  deviceId String
  ts       DateTime        @default(now())
  type     DeviceEventType
  detail   Json?
  device   Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, ts(sort: Desc)])
}

// Config push with acknowledgement states (US-INC-003)
model DeviceConfig {
  id         String      @id @default(uuid())
  deviceId   String
  version    Int // monotonic per device
  payload    Json
  state      ConfigState @default(sent)
  sentAt     DateTime    @default(now())
  receivedAt DateTime?
  appliedAt  DateTime?
  device     Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, version])
}

// ── Incubation ───────────────────────────────────────────────────

enum BatchStatus {
  planned
  setting
  incubating
  lockdown
  hatching
  completed
  closed
  aborted
}

model EggCollection {
  id             String           @id @default(uuid())
  farmId         String
  collectedOn    DateTime // date eggs were collected (BR-011 age basis)
  count          Int
  discardedCount Int              @default(0)
  discardNote    String?
  avgWeightGrams Float?
  sourceNote     String? // free-text detail (e.g. "coop 1"); flockId is the primary link (Phase 2)
  flockId        String?
  clientId       String?          @unique // offline-sync idempotency (BR-010)
  createdAt      DateTime         @default(now())
  farm           Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  flock          Flock?           @relation(fields: [flockId], references: [id])
  batchSources   BatchEggSource[]

  @@index([farmId, collectedOn(sort: Desc)])
}

model EggBatch {
  id                    String            @id @default(uuid())
  farmId                String
  incubatorId           String
  speciesId             String
  status                BatchStatus       @default(planned)
  setAt                 DateTime?
  candlingDays          Int[] // day numbers, from Species at creation (BR-008)
  lockdownAt            DateTime?
  expectedHatchAt       DateTime?
  // Mirrored as-is from the bound device's own telemetry (day/hatchEpoch,
  // EGG profile only) whenever this batch is the incubator's active one.
  // Read-only cross-check — never overwrites setAt/expectedHatchAt, which
  // stay a purely manual record set via /set (BR-009-style traceability).
  deviceDay             Int?
  deviceExpectedHatchAt DateTime?
  viableCount           Int               @default(0) // maintained by candling results (BR-003)
  fertilityPct          Float? // BR-015: stored at completion, never recomputed
  hatchOfSetPct         Float?
  hatchOfFertilePct     Float?
  abortReason           String?
  storageOverrideNote   String? // BR-011: why >14-day eggs were set anyway
  createdAt             DateTime          @default(now())
  farm                  Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  incubator             Incubator         @relation(fields: [incubatorId], references: [id])
  species               Species           @relation(fields: [speciesId], references: [id])
  sources               BatchEggSource[]
  candlings             CandlingSession[]
  hatch                 HatchEvent?

  @@index([farmId, status])
}

model BatchEggSource {
  batchId      String
  collectionId String
  count        Int
  batch        EggBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  collection   EggCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([batchId, collectionId])
}

model CandlingSession {
  id              String   @id @default(uuid())
  batchId         String
  dayNo           Int
  candledAt       DateTime
  fertile         Int
  clear           Int
  bloodRing       Int
  unsure          Int
  discrepancyNote String? // BR-003: mismatches recorded, not absorbed
  recordedById    String? // User id (cross-context, no FK)
  clientId        String?  @unique // offline-sync idempotency (BR-010)
  createdAt       DateTime @default(now())
  batch           EggBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, dayNo])
}

model HatchEvent {
  id              String   @id @default(uuid())
  batchId         String   @unique
  hatchedAt       DateTime
  hatched         Int
  pippedDead      Int
  deadInShell     Int
  unhatched       Int
  discrepancyNote String?
  recordedById    String?
  clientId        String?  @unique
  createdAt       DateTime @default(now())
  batch           EggBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  flock           Flock? // reverse of Flock.hatchEventId — set when this hatch becomes a tracked flock
}

// ── Alerting ─────────────────────────────────────────────────────

enum AlertSeverity {
  warning
  critical
}

enum AlertState {
  open
  acked
  resolved
}

// Overrides only — default bounds come from Species (stage-aware, BR-006)
model AlertRule {
  id             String   @id @default(uuid())
  farmId         String
  incubatorId    String?
  metric         String // "temp_c" | "humidity_pct" (validated in app layer)
  warnMin        Float?
  warnMax        Float?
  critMin        Float?
  critMax        Float?
  sustainMinutes Int      @default(10)
  quietHours     Json? // { start: "22:00", end: "06:00" } — warnings only (BR-014)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  farm           Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId])
}

model Alert {
  id              String        @id @default(uuid())
  farmId          String
  ruleId          String?
  incubatorId     String?
  deviceId        String?
  flockId         String? // US-FED-003/US-WTR-002 consumption anomalies
  inventoryItemId String? // US-INV-003 low-stock/expiry warnings
  severity        AlertSeverity
  state           AlertState    @default(open)
  message         String
  triggeredAt     DateTime      @default(now())
  ackedAt         DateTime?
  ackedById       String? // User id (cross-context, no FK)
  resolvedAt      DateTime?
  farm            Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId, state, triggeredAt(sort: Desc)])
}

model Notification {
  id       String    @id @default(uuid())
  userId   String
  alertId  String?
  kind     String // "alert" | "candling_due" | "vaccination_due" | ...
  title    String
  body     String
  deepLink String?
  channel  String // "fcm" | "web"
  sentAt   DateTime?
  readAt   DateTime?

  @@index([userId, sentAt(sort: Desc)])
}

// ── Flock Operations (Phase 2) ───────────────────────────────────

enum FlockPurpose {
  layer
  broiler
  breeder
}

enum MortalityCause {
  death
  cull
  sale
}

enum FlockStage {
  brooding
  grower
  pre_lay
  layer
  broiler_starter
  broiler_grower
  broiler_finisher
}

model Flock {
  id                 String              @id @default(uuid())
  farmId             String
  name               String
  speciesId          String
  purpose            FlockPurpose
  // Origin is exactly one of these two (BR-009 traceability): a flock
  // either comes from a completed hatch (hatchEventId set) or was
  // acquired manually (acquisitionDate + acquisitionAgeDays set, an
  // explicit provenance note required so origin is never unknown).
  hatchEventId       String?             @unique
  acquisitionDate    DateTime?
  acquisitionAgeDays Int?
  acquisitionNote    String?
  placedCount        Int // ledger base — current count is always derived, never edited directly (BR-009)
  // Manual correction for when derived stage (purpose + age) doesn't match
  // reality — age/origin data entered wrong at creation, etc. Null means
  // "derive from age" (the default); set means "use this instead."
  stageOverride      FlockStage?
  createdAt          DateTime            @default(now())
  farm               Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  species            Species             @relation(fields: [speciesId], references: [id])
  hatchEvent         HatchEvent?         @relation(fields: [hatchEventId], references: [id])
  mortalityRecords   MortalityRecord[]
  vaccinationRecords VaccinationRecord[]
  feedLogs           FeedLog[]
  waterLogs          WaterLog[]
  eggCollections     EggCollection[]

  @@index([farmId])
}

// The only way a flock's count changes (BR-009) — current = placed +
// additions(none modeled yet, no restocking UI) − deaths − culls − sales.
model MortalityRecord {
  id           String         @id @default(uuid())
  flockId      String
  date         DateTime
  count        Int
  cause        MortalityCause
  notes        String?
  recordedById String? // User id (cross-context, no FK)
  clientId     String?        @unique // offline-sync idempotency (BR-010)
  createdAt    DateTime       @default(now())
  flock        Flock          @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, date(sort: Desc)])
}

// Farm-scoped, not global: US-VAC-001 templates are editable starting
// points seeded from domain-knowledge §6, not hardcoded truth — each
// farm can diverge from the seed.
model VaccinationTemplateItem {
  id          String              @id @default(uuid())
  farmId      String
  speciesId   String
  purpose     FlockPurpose
  ageDaysFrom Int
  ageDaysTo   Int
  vaccine     String
  disease     String
  route       String
  createdAt   DateTime            @default(now())
  farm        Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  species     Species             @relation(fields: [speciesId], references: [id])
  records     VaccinationRecord[]

  @@index([farmId, speciesId, purpose])
}

// Immutable once saved (BR-005) — the service layer never updates a row
// after creation; corrections are new rows with amendsRecordId set.
// amendsRecordId always points at the true original (not the previous
// amendment), so every amendment in a chain is one hop from the source.
model VaccinationRecord {
  id              String                   @id @default(uuid())
  flockId         String
  templateItemId  String?
  date            DateTime
  vaccine         String
  disease         String
  manufacturer    String?
  lotNumber       String?
  expiry          DateTime?
  route           String
  dose            String?
  count           Int
  administeredBy  String
  reactions       String?
  nextDueDate     DateTime?
  amendsRecordId  String?
  inventoryItemId String? // US-INV-002 auto-deduction source
  recordedById    String? // User id (cross-context, no FK)
  clientId        String?                  @unique // offline-sync idempotency (BR-010)
  createdAt       DateTime                 @default(now())
  flock           Flock                    @relation(fields: [flockId], references: [id], onDelete: Cascade)
  templateItem    VaccinationTemplateItem? @relation(fields: [templateItemId], references: [id])
  amendsRecord    VaccinationRecord?       @relation("Amendment", fields: [amendsRecordId], references: [id])
  amendments      VaccinationRecord[]      @relation("Amendment")
  inventoryItem   InventoryItem?           @relation(fields: [inventoryItemId], references: [id])

  @@index([flockId, date(sort: Desc)])
}

// BR-012: one record per flock per check, standardized units.
model FeedLog {
  id              String         @id @default(uuid())
  flockId         String
  loggedAt        DateTime
  feedType        String
  quantityKg      Float
  stageMismatch   Boolean        @default(false) // US-FED-002, computed at write time
  inventoryItemId String? // US-INV-002 auto-deduction source
  recordedById    String?
  clientId        String?        @unique // offline-sync idempotency (BR-010)
  createdAt       DateTime       @default(now())
  flock           Flock          @relation(fields: [flockId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([flockId, loggedAt(sort: Desc)])
}

model WaterLog {
  id             String   @id @default(uuid())
  flockId        String
  loggedAt       DateTime
  quantityLiters Float
  recordedById   String?
  clientId       String?  @unique // offline-sync idempotency (BR-010)
  createdAt      DateTime @default(now())
  flock          Flock    @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, loggedAt(sort: Desc)])
}

// ── Inventory (Phase 3) ──────────────────────────────────────────

enum InventoryItemKind {
  feed
  vaccine
  consumable
}

enum StockTransactionCause {
  feed_log
  vaccination
  manual
}

model InventoryItem {
  id                 String              @id @default(uuid())
  farmId             String
  kind               InventoryItemKind
  name               String
  unit               String // "kg" | "L" | "doses" | free text
  quantity           Float               @default(0) // current stock — updated transactionally alongside each StockTransaction, not derived on read
  lotNumber          String?
  expiry             DateTime?
  lowStockThreshold  Float?
  createdAt          DateTime            @default(now())
  farm               Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  transactions       StockTransaction[]
  feedLogs           FeedLog[]
  vaccinationRecords VaccinationRecord[]

  @@index([farmId])
}

// Audit ledger for every quantity change — InventoryItem.quantity is the
// fast-read current value, this is the append-only history behind it.
model StockTransaction {
  id        String                @id @default(uuid())
  itemId    String
  delta     Float // negative = deduction, positive = restock/correction
  cause     StockTransactionCause
  refId     String? // FeedLog.id / VaccinationRecord.id that triggered this, null for manual
  note      String?
  createdAt DateTime              @default(now())
  item      InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt(sort: Desc)])
}
