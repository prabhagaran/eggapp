<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ requires runtime consent for notifications; requested
         from MainActivity after login (see LoginScreen navigation). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:theme="@style/Theme.EggAppField"
        android:usesCleartextTraffic="true">
        <!-- usesCleartextTraffic: API is plain HTTP on the LAN (no TLS
             cert available for a bare IP address) — acceptable for a
             personal LAN-only deployment; revisit if ever exposed
             beyond the LAN (see ADR 0006 consequences). -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.EggAppField">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".push.EggAppMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Default notification channel used by EggAppMessagingService. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/fcm_default_channel_id" />
    </application>
</manifest>
