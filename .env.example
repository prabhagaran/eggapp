# Copy to packages/db/.env (Prisma) and apps/api/.env (runtime). Never commit .env files.

# Supabase Postgres (Settings → Database in the Supabase dashboard)
# Pooled connection (port 6543, PgBouncer) — used by the app at runtime:
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (port 5432) — used by Prisma migrations. Use THIS host,
# not the "Direct connection" string the dashboard also shows
# (db.<project-ref>.supabase.co) — that one is IPv6-only and unreachable
# from many networks/ISPs.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"
# If your password has special characters (@ / : ? # etc.), percent-encode
# them in both URLs above (@ -> %40, / -> %2F, ...) or the URL won't parse.

# API
PORT=3001
JWT_SECRET="generate-a-long-random-string"

# MQTT broker (infra/docker) — per-device credentials, see infra/docker/mosquitto/README.md
MQTT_URL="mqtt://localhost:1883"
MQTT_API_USERNAME="api-ingest"
MQTT_API_PASSWORD=""

# Firebase Cloud Messaging (Phase 1) — path to service-account JSON, keep outside repo
FCM_SERVICE_ACCOUNT_PATH=""
